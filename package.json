{
  "name": "amalia",
  "version": "0.1.0",
  "description": "Orquestador multi-agente sobre git worktrees",
  "type": "module",
  "bin": {
    "amalia": "bin/amalia.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "bin",
    "templates",
    "dashboard",
    "src/db/schema.sql"
  ],
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "copy-assets": "node -e \"require('fs').cpSync('src/db/schema.sql', 'dist/db/schema.sql', {force:true})\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=24"
  },
  "license": "MIT",
  "dependencies": {
    "commander": "^12.0.0",
    "express": "^4.18.2",
    "gray-matter": "^4.0.3",
    "socket.io": "^4.7.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
